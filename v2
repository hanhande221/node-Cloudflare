// ==================== 配置 ====================
const CFG = {
  id: '757e052c-4159-491d-bc5d-1b6bd866d980',
  chunk: 64 * 1024,
  dnPack: 32 * 1024,
  dnTail: 512,
  dnMs: 0,
  upPack: 16 * 1024,
  upQMax: 256 * 1024,
  maxED: 8 * 1024,
  concur: 4,
  proxyListUrl: 'https://raw.githubusercontent.com/hanhande221/node-Cloudflare/main/ip.txt',
  fallbackProxy: '', // 备用 proxyIP，格式 "1.2.3.4:443" 或留空
  subPath: '/sub',
};

// ==================== UUID 解析 ====================
const hex = c => (c > 64 ? c + 9 : c) & 0xF;
const idB = new Uint8Array(16), dec = new TextDecoder();
for (let i = 0, p = 0, c, h; i < 16; i++) {
  c = CFG.id.charCodeAt(p++); c === 45 && (c = CFG.id.charCodeAt(p++)); h = hex(c);
  c = CFG.id.charCodeAt(p++); c === 45 && (c = CFG.id.charCodeAt(p++)); idB[i] = h << 4 | hex(c);
}
const [I0,I1,I2,I3,I4,I5,I6,I7,I8,I9,I10,I11,I12,I13,I14,I15] = idB;
const matchID = c => c[1]===I0&&c[2]===I1&&c[3]===I2&&c[4]===I3&&c[5]===I4&&c[6]===I5&&c[7]===I6&&c[8]===I7&&c[9]===I8&&c[10]===I9&&c[11]===I10&&c[12]===I11&&c[13]===I12&&c[14]===I13&&c[15]===I14&&c[16]===I15;

const addr = (t, b) => t === 1 ? `${b[0]}.${b[1]}.${b[2]}.${b[3]}` : t === 3 ? dec.decode(b) : `[${Array.from({length:8},(_,i)=>((b[i*2]<<8)|b[i*2+1]).toString(16)).join(':')}]`;
const parseAddr = (b, o, t) => { const l = t===3?b[o++]:t===1?4:t===4?16:null; if(l===null)return null; const n=o+l; return n>b.length?null:{targetAddrBytes:b.subarray(o,n),dataOffset:n}; };
const vless = c => { if(c.length<24||!matchID(c))return null; let o=19+c[17]; const p=(c[o]<<8)|c[o+1]; let t=c[o+2]; if(t!==1)t+=1; const a=parseAddr(c,o+3,t); return a?{addrType:t,...a,port:p}:null; };

// ==================== 优选 IP 管理 ====================
// Workers 的全局变量在同一个 isolate 内是共享的，可做简单缓存
let _proxyList = null;
let _proxyFetchedAt = 0;
const PROXY_TTL = 5 * 60 * 1000;

function parseProxyLine(line) {
  line = line.trim();
  if (!line || line.startsWith('#') || line.startsWith('//')) return null;
  let name = '';
  const hi = line.indexOf('#');
  if (hi !== -1) { name = line.slice(hi + 1).trim(); line = line.slice(0, hi).trim(); }
  const ipv6 = line.match(/^\[(.+)\]:(\d+)$/);
  if (ipv6) return { host: ipv6[1], port: parseInt(ipv6[2]), name };
  const lc = line.lastIndexOf(':');
  if (lc === -1) return null;
  const host = line.slice(0, lc), port = parseInt(line.slice(lc + 1));
  if (!host || isNaN(port)) return null;
  return { host, port, name };
}

async function getProxyList() {
  const now = Date.now();
  if (_proxyList && now - _proxyFetchedAt < PROXY_TTL) return _proxyList;
  try {
    const r = await fetch(CFG.proxyListUrl, { cf: { cacheTtl: 300, cacheEverything: true } });
    if (r.ok) {
      const lines = (await r.text()).split('\n').map(parseProxyLine).filter(Boolean);
      if (lines.length) { _proxyList = lines; _proxyFetchedAt = now; }
    }
  } catch (e) { console.error('proxy list fetch error:', e); }
  // 若还是空，返回空数组
  return _proxyList || [];
}

// ==================== CF IP 检测 ====================
// 这些域名的 IP 属于 CF 自己的网络，Worker 直连会回环，必须走 proxyIP
const CF_HOST_RE = /(?:^|\.)(?:cloudflare\.com|cloudflarestatus\.com|cf-assets\.com|workers\.dev|pages\.dev|r2\.dev|trycloudflare\.com)$/i;
const isCFHost = h => CF_HOST_RE.test(h);

// ==================== 连接核心 ====================
/**
 * proxyIP 用法说明：
 *   Cloudflare Workers 的 connect() 实际上是通过 CF 的全球网络发起 TCP。
 *   当目标 IP 也属于 CF 网络时，CF 会拒绝/回环此连接。
 *   解决方案：改用一个"优选 IP"作为连接的物理目标，
 *   但 hostname 参数仍填写原始目标域名，CF 的底层会用 hostname 做 SNI 路由。
 *   即：connect({ hostname: 原始域名, port: 原始端口 })
 *       但通过 fetcher 参数覆盖实际连接的 IP。
 *
 *   注意：Workers 的 connect() 没有直接替换 IP 的 API，
 *   但可以在 hostname 填 proxyIP，然后通过 allowHalfOpen + 自定义 header 实现，
 *   实际更简单的方式是：connect({ hostname: proxyIP, port: proxyPort })，
 *   依赖 proxyIP 本身是 CF anycast IP，CF 网络会根据 TLS SNI 路由到正确目标。
 *   这就是社区常见 proxyIP 方案的本质。
 */

const tcpConnect = (fetcher, hostname, port) => {
  const s = fetcher.connect({ hostname, port });
  return s.opened.then(() => s);
};

const tcpRace = (fetcher, hostname, port) => {
  if (!fetcher?.connect) return Promise.reject(new Error('no connect'));
  if (CFG.concur <= 1) return tcpConnect(fetcher, hostname, port);
  const attempts = Array.from({ length: CFG.concur }, () => tcpConnect(fetcher, hostname, port));
  return Promise.any(attempts).then(winner => {
    attempts.forEach(p => p.then(s => s !== winner && s.close()).catch(() => {}));
    return winner;
  });
};

/**
 * 智能连接：
 * - 普通目标：直接连，失败后逐一尝试 proxyList 中的 IP 作为跳板
 * - CF 自身域名：跳过直连，直接用 proxyList 里的 IP 替换目标 IP 建立连接
 *
 * proxyIP 连接原理：connect({ hostname: proxyIP, port: targetPort })
 * CF 边缘节点收到连接后，会根据 TLS ClientHello 里的 SNI（由客户端发送的原始域名）
 * 转发到正确的后端，因此数据传输是正确的。
 */
async function smartConnect(fetcher, targetHost, targetPort) {
  const needProxy = isCFHost(targetHost);

  // 普通目标：先尝试直连
  if (!needProxy) {
    try {
      return await tcpRace(fetcher, targetHost, targetPort);
    } catch (_) {
      // 直连失败，走 proxyIP 回退
    }
  }

  // 获取候选列表
  const list = await getProxyList();
  const candidates = [...list];
  if (CFG.fallbackProxy) {
    const fb = parseProxyLine(CFG.fallbackProxy);
    if (fb) candidates.push(fb);
  }

  // 无候选：CF域名只能放弃，普通域名已经直连失败，也放弃
  if (!candidates.length) {
    throw new Error(`No proxy available for ${targetHost}:${targetPort}`);
  }

  // 依次尝试每个 proxyIP
  for (const proxy of candidates) {
    try {
      // 关键：hostname 填 proxyIP（替换物理 IP），port 仍用目标端口
      // CF 网络会根据后续 TLS SNI 正确路由
      return await tcpConnect(fetcher, proxy.host, targetPort);
    } catch (e) {
      console.log(`proxy ${proxy.host}:${targetPort} failed: ${e?.message}`);
    }
  }

  throw new Error(`All connections failed for ${targetHost}:${targetPort}`);
}

// ==================== 队列 ====================
const mkQ = (cap, qCap = cap, itemsMax = Math.max(1, qCap >> 8)) => {
  let q = [], h = 0, qB = 0, buf = null;
  const trim = () => { h > 32 && h * 2 >= q.length && (q = q.slice(h), h = 0); };
  const take = () => { if (h >= q.length) return null; const d = q[h]; q[h++] = undefined; qB -= d.byteLength; trim(); return d; };
  return {
    get bytes() { return qB; }, get size() { return q.length - h; }, get empty() { return h >= q.length; },
    clear() { q = []; h = 0; qB = 0; },
    sow(d) { const n = d?.byteLength || 0; if (!n) return 1; if (qB + n > qCap || q.length - h >= itemsMax) return 0; q.push(d); qB += n; return 1; },
    bundle(d) {
      d ||= take(); if (!d || h >= q.length || d.byteLength >= cap) return [d, 0];
      let n = d.byteLength, e = h;
      while (e < q.length) { const x = q[e], nn = n + x.byteLength; if (nn > cap) break; n = nn; e++; }
      if (e === h) return [d, 0];
      const out = buf ||= new Uint8Array(cap); out.set(d);
      for (let o = d.byteLength; h < e;) { const x = q[h]; q[h++] = undefined; qB -= x.byteLength; out.set(x, o); o += x.byteLength; }
      trim(); return [out.subarray(0, n), 1];
    }
  };
};

// ==================== 下行缓冲 ====================
const mkDn = w => {
  const cap = CFG.dnPack, tail = CFG.dnTail, low = Math.max(4096, tail << 3);
  let pb = new Uint8Array(cap), p = 0, tp = 0, mq = 0, gen = 0, qk = 0, qr = 0;
  const reap = () => { tp && clearTimeout(tp); tp = 0; mq = 0; if (!p) return; w.send(pb.subarray(0, p).slice()); pb = new Uint8Array(cap); p = 0; qr = 0; };
  const ripen = () => {
    if (tp || mq) return; mq = 1; qk = gen;
    queueMicrotask(() => {
      mq = 0; if (!p || tp) return;
      if (cap - p < tail) return reap();
      tp = setTimeout(() => { tp = 0; if (!p) return; if (cap - p < tail) return reap(); if (qr < 2 && (gen !== qk || p < low)) { qr++; qk = gen; return ripen(); } reap(); }, Math.max(CFG.dnMs, 1));
    });
  };
  return {
    send(u) { let o = 0, n = u?.byteLength || 0; if (!n) return; while (o < n) { if (!p && n - o >= cap) { const m = Math.min(cap, n - o); w.send(o || m !== n ? u.subarray(o, o + m) : u); o += m; continue; } const m = Math.min(cap - p, n - o); pb.set(u.subarray(o, o + m), p); p += m; o += m; gen++; if (p === cap || cap - p < tail) reap(); else ripen(); } },
    reap
  };
};

const mill = async (rd, w) => {
  const r = rd.getReader({ mode: 'byob' }), tx = mkDn(w); let buf = new ArrayBuffer(CFG.chunk);
  try { for (;;) { const { done, value: v } = await r.read(new Uint8Array(buf, 0, CFG.chunk)); if (done) break; if (!v?.byteLength) continue; if (v.byteLength >= (CFG.chunk >> 1)) tx.reap(), w.send(v), buf = new ArrayBuffer(CFG.chunk); else tx.send(v.slice()), buf = v.buffer; } tx.reap(); } catch {}
  finally { try { tx.reap(); } catch {} try { r.releaseLock(); } catch {} }
};

// ==================== 订阅 ====================
async function handleSub(req) {
  const url = new URL(req.url);
  const workerHost = url.hostname;
  const list = await getProxyList();
  const entries = list.length ? list : [{ host: workerHost, port: 443, name: 'Default' }];

  const links = entries.map(({ host: ph, port: pp, name }) => {
    const params = new URLSearchParams({
      encryption: 'none', security: 'tls', sni: workerHost,
      fp: 'randomized', type: 'ws', host: workerHost, path: '/',
    });
    return `vless://${CFG.id}@${ph}:${pp}?${params}#${encodeURIComponent(name || `${ph}:${pp}`)}`;
  });

  const b64 = btoa(unescape(encodeURIComponent(links.join('\n'))));
  return new Response(b64, {
    headers: {
      'Content-Type': 'text/plain; charset=utf-8',
      'Cache-Control': 'no-store',
      'Subscription-Userinfo': 'upload=0; download=0; total=10737418240000000; expire=99999999999',
    }
  });
}

// ==================== WebSocket 处理 ====================
const wsHandler = async req => {
  const [client, server] = Object.values(new WebSocketPair());
  server.accept({ allowHalfOpen: true });
  server.binaryType = 'arraybuffer';
  const fetcher = req.fetcher;

  const edStr = req.headers.get('sec-websocket-protocol');
  const ed = edStr && edStr.length <= CFG.maxED * 4 / 3 + 4
    ? Uint8Array.fromBase64(edStr, { alphabet: 'base64url' })
    : null;

  let curW = null, sock = null, closed = false, busy = false;
  const uq = mkQ(CFG.upPack, CFG.upQMax, CFG.upQMax >> 8);

  const wither = () => {
    if (closed) return; closed = true; uq.clear();
    try { curW?.releaseLock(); } catch {}
    try { sock?.close(); } catch {}
    try { server.close(); } catch {}
  };

  const toU8 = d => d instanceof Uint8Array ? d : ArrayBuffer.isView(d) ? new Uint8Array(d.buffer, d.byteOffset, d.byteLength) : new Uint8Array(d);
  const sow = d => { const u = toU8(d); if (!u.byteLength) return 1; if (uq.sow(u)) return 1; wither(); return 0; };

  const thresh = async () => {
    if (busy || closed) return; busy = true;
    try {
      for (;;) {
        if (closed) break;
        if (!sock) {
          const [d] = uq.bundle();
          if (!d) break;
          const r = vless(d);
          if (!r) { wither(); break; }
          server.send(new Uint8Array([d[0], 0]));
          const targetHost = addr(r.addrType, r.targetAddrBytes);
          const targetPort = r.port;
          const payload = d.subarray(r.dataOffset);

          sock = await smartConnect(fetcher, targetHost, targetPort);
          curW = sock.writable.getWriter();
          const [first] = uq.bundle(payload);
          if (first?.byteLength) await curW.write(first);
          mill(sock.readable, server).finally(() => wither());
          continue;
        }
        const [d] = uq.bundle();
        if (!d) break;
        await curW.write(d);
      }
    } catch { wither(); }
    finally { busy = false; if (!uq.empty && !closed) queueMicrotask(thresh); }
  };

  if (ed && sow(ed)) thresh();
  server.addEventListener('message', e => { if (!closed) sow(e.data) && thresh(); });
  server.addEventListener('close', () => wither());
  server.addEventListener('error', () => wither());

  return new Response(null, { status: 101, webSocket: client, headers: { 'Sec-WebSocket-Extensions': '' } });
};

// ==================== 入口 ====================
export default {
  async fetch(req) {
    const url = new URL(req.url);
    if (url.pathname === CFG.subPath) return handleSub(req);
    if (req.headers.get('Upgrade')?.toLowerCase() === 'websocket') return wsHandler(req);
    return new Response('Hello world!');
  }
};
